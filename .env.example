# Copy to a file OUTSIDE the repo (we use ~/.config/trinity/secrets.env) and
# `source` it before running. NEVER put real values in a file inside this repo.
#
#   cp .env.example ~/.config/trinity/secrets.env   # then fill in + chmod 600
#   source ~/.config/trinity/secrets.env

# Fireworks AI — serves the three coordinated LLMs (deepseek-v4-pro, glm-5p2, kimi-k2p6)
export FIREWORKS_API_KEY="fw_xxx_your_key_here"

# Remote GPU box (SSH alias defined in ~/.ssh/config as `trinity-gpu`)
export TRINITY_GPU_HOST="trinity-gpu"

# Which physical GPU we are allowed to use on the box (0-indexed). We are
# allocated GPU 5 ONLY — every remote command must pin CUDA_VISIBLE_DEVICES=5.
export TRINITY_GPU_INDEX="5"
